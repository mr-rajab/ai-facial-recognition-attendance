# Copy to `.env` in this folder. `web_app.py` auto-loads `.env` on startup (python-dotenv).
# Do not commit `.env` (it is gitignored).

# Session cookie signing (change in production)
SECRET_KEY=local-dev-only-change-me-32chars-min

# First-time setup: when the `users` table is empty, the server creates one admin from these
# values on startup. Remove or leave unset after you have created accounts.
BOOTSTRAP_ADMIN_EMAIL=you@university.edu
BOOTSTRAP_ADMIN_PASSWORD=your-secure-password

# Optional: quick attendance (pre-login face match) tuning
# QUICK_ATTEND_MIN_SIM=0.35
# QUICK_ATTEND_MIN_DET_SCORE=0.25

# Student attendance: selfie must match this student’s gallery template (same thresholds as quick if unset)
# ATTEND_IDENTITY_MIN_SIM=0.35
# ATTEND_IDENTITY_MIN_DET_SCORE=0.25

# Rate limiting (SlowAPI). Set to 0 only for special test setups.
# RATE_LIMIT_ENABLED=1

# Web bind (optional)
# HOST=127.0.0.1
# PORT=8000
